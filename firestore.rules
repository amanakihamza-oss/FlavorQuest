rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    
    // Vérifie si l'utilisateur est connecté à Firebase Auth
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Vérifie si l'utilisateur connecté est un administrateur
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email.matches('.*@flavorquest.be') || 
        request.auth.token.email.matches('.*@flavorquest.com') ||
        request.auth.token.email == 'admin@flavorquest.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }
    
    // --- Lieux (Places) ---
    match /places/{placeId} {
      allow read: if true;
      // Création autorisée pour tout utilisateur connecté (statut en attente)
      allow create: if isAuthenticated() && request.resource.data.validationStatus == 'pending';
      // Mises à jour et suppressions réservées aux administrateurs
      allow update, delete: if isAdmin(); 
    }
    
    // --- Avis (Reviews) ---
    match /reviews/{reviewId} {
      allow read: if true;
      // CORRECTION : Tout le monde peut poster un avis (sans compte obligatoire)
      allow create: if true;
      // Suppression autorisée pour l'auteur de l'avis ou pour un admin
      allow delete: if isAuthenticated() && (
        request.auth.uid == resource.data.userId || isAdmin()
      );
    }
    
    // --- Articles (Blog) ---
    match /articles/{articleId} {
      allow read: if true;
      // Seuls les admins peuvent créer ou supprimer un article
      allow create, delete: if isAdmin();
      // Tout le monde peut mettre à jour l'article SI ET SEULEMENT SI seul le champ 'likes' est modifié (pour le vote public).
      // Sinon, la mise à jour complète est réservée aux admins.
      allow update: if isAdmin() || (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes'])
      );
    }
    
    // --- Utilisateurs ---
    match /users/{userId} {
      // Un utilisateur ne peut lire/écrire que son propre document utilisateur
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }
    
    // --- Demandes de revendication (Claim Requests) ---
    match /claim_requests/{claimId} {
      // Les propriétaires de restaurant peuvent faire une demande de revendication sans compte
      allow create: if true; 
      // Seuls les admins peuvent lire ou modifier les demandes (pour traitement/validation)
      allow read, write: if isAdmin();
    }
  }
}
